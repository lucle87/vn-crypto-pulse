# Vi nhan tien (USDT0/pathUSD). Bat buoc. Dien CA HAI dong giong nhau:
RECIPIENT_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE
NEXT_PUBLIC_RECIPIENT_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Mang: testnet (mac dinh) hoac mainnet.
TEMPO_NETWORK=testnet

# Gia moi call.
NEWS_PRICE=0.020000
NEWS_PRICE_AMOUNT=0.02

# URL cong khai sau khi deploy (KHONG dau / cuoi). Vd https://vn-crypto-pulse.vercel.app
BASE_URL=http://localhost:3000

# Groq key (console.groq.com) de dich + tom tat sang tieng Anh.
# De trong -> tra tieu de tieng Viet tho (van chay, chi khong dich).
GROQ_API_KEY=

# Email lien he (verify ownership tren mppscan).
CONTACT_EMAIL=

# Secret ky MPP challenge (chuoi ngau nhien, giu co dinh).
MPP_SECRET_KEY=
